{
  "name": "earningsflow",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "earningsflow",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "scripts"
      ],
      "devDependencies": {}
    },
    "node_modules/@earningsflow/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@earningsflow/data": {
      "resolved": "packages/data",
      "link": true
    },
    "node_modules/@earningsflow/reports": {
      "resolved": "packages/reports",
      "link": true
    },
    "node_modules/@earningsflow/scripts": {
      "resolved": "scripts",
      "link": true
    },
    "node_modules/@earningsflow/server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/@earningsflow/worker": {
      "resolved": "packages/worker",
      "link": true
    },
    "node_modules/@earningsflow/workflows": {
      "resolved": "packages/workflows",
      "link": true
    },
    "packages/core": {
      "name": "@earningsflow/core",
      "version": "0.1.0"
    },
    "packages/data": {
      "name": "@earningsflow/data",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/core": "0.1.0"
      }
    },
    "packages/reports": {
      "name": "@earningsflow/reports",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/core": "0.1.0"
      }
    },
    "packages/server": {
      "name": "@earningsflow/server",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/workflows": "0.1.0"
      }
    },
    "packages/worker": {
      "name": "@earningsflow/worker",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/reports": "0.1.0",
        "@earningsflow/workflows": "0.1.0"
      }
    },
    "packages/workflows": {
      "name": "@earningsflow/workflows",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/core": "0.1.0",
        "@earningsflow/data": "0.1.0"
      }
    },
    "scripts": {
      "name": "@earningsflow/scripts",
      "version": "0.1.0",
      "dependencies": {
        "@earningsflow/reports": "0.1.0",
        "@earningsflow/workflows": "0.1.0"
      }
    }
  }
}
